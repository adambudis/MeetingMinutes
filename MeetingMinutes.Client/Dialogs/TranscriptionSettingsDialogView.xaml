<UserControl x:Class="MeetingMinutes.Dialogs.TranscriptionSettingsDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <StackPanel Margin="24" Width="320">

        <TextBlock Text="Nastavení přepisu"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,16"/>

        <ComboBox x:Name="TranscriptionModelComboBox"
                  materialDesign:HintAssist.Hint="Model přepisu"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  SelectionChanged="TranscriptionModelComboBox_SelectionChanged">
            <ComboBoxItem Content="canary"/>
            <ComboBoxItem Content="parakeet"/>
        </ComboBox>

        <ComboBox x:Name="TranscriptionLanguageComboBox"
                  Margin="0,12,0,0"
                  materialDesign:HintAssist.Hint="Jazyk (pouze Canary)"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
            <ComboBoxItem Content="cs"/>
            <ComboBoxItem Content="en"/>
        </ComboBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Null}"
                    Content="ZRUŠIT"/>
            <Button x:Name="SaveButton"
                    Margin="8,0,0,0"
                    Click="SaveButton_Click"
                    Content="ULOŽIT"/>
        </StackPanel>

    </StackPanel>
</UserControl>
